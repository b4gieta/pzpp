<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - pzpp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/pzpp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mainpage.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="main_header">
        <div class="logo">
            @* Tutaj logo *@
        </div>
        <div class="menu">
            @* Tutaj na sztywno wpisać guziki przekierowujące na inne podstrony *@
        </div>
        <div class="user_panel d-flex flex-column justify-content-end align-items-center pb-3">
            @* Bedzie trzeba sprawdzac, czy zalogowany *@
            <form class="d-flex mb-2 w-100 px-3">
                <input type="text" class="form-control form-control-sm me-2" placeholder="Login" required>
                <input type="password" class="form-control form-control-sm me-2" placeholder="Hasło" required>
                <button type="submit" class="btn btn-sm" style="background-color: #FFA31A; color: #000; font-weight: bold;">Zaloguj</button>
            </form>
            <div class="d-flex align-items-center mt-1">
                <span class="small me-2 text-white">Nie masz konta?</span>
                <button type="button" class="btn btn-sm btn-outline-light" style="border-color: #FFA31A; color: #FFA31A;" data-bs-toggle="modal" data-bs-target="#registerModal">
                    Zarejestruj się
                </button>
            </div>
        </div>
    </div>
    <div class="main_container">
        @RenderBody()
    </div>
    <div class="main_footer"></div>

    @* <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">pzpp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - pzpp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    *@

    <!-- Rejestracja pop-up -->
    <div class="modal fade" id="registerModal" tabindex="-1" aria-labelledby="registerModalLabel" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content" style="background-color: #292929; color: white; border: 1px solid #FFA31A;">
          <div class="modal-header border-bottom-0">
            <h5 class="modal-title" id="registerModalLabel">Rejestracja</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Zamknij"></button>
          </div>
          <div class="modal-body">
            <form>
              <div class="mb-3">
                <label for="registerName" class="form-label">Nazwa użytkownika</label>
                <input type="text" class="form-control" id="registerName" required>
              </div>
              <div class="mb-3">
                <label for="registerEmail" class="form-label">Adres email</label>
                <input type="email" class="form-control" id="registerEmail" required>
              </div>
              <div class="mb-3">
                <label for="registerPassword" class="form-label">Hasło</label>
                <input type="password" class="form-control" id="registerPassword" required>
              </div>
              <div class="mb-3">
                <label for="registerConfirmPassword" class="form-label">Potwierdź hasło</label>
                <input type="password" class="form-control" id="registerConfirmPassword" required>
              </div>
              <button type="submit" class="btn w-100 mt-2" style="background-color: #FFA31A; color: black; font-weight: bold;">Zarejestruj się</button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
