<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - pzpp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/pzpp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mainpage.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="main_header">
        <div class="logo">
            @* Tutaj logo *@
        </div>
        <div class="menu">
            @* Tutaj na sztywno wpisać guziki przekierowujące na inne podstrony *@
        </div>
            @* Logowanie *@
        @{
            var currentUser = Context.Session.GetString("user");
        }
        <div class="user_panel d-flex flex-column justify-content-end align-items-center pb-3">
            @if (!string.IsNullOrEmpty(currentUser))
            {
                <div class="d-flex flex-column justify-content-center align-items-center w-100 mb-4">
                    <span class="text-white mb-2">Witaj, @currentUser!</span>
                    <button id="logoutBtn" type="button" class="btn btn-sm" style="background-color: #FFA31A; color: #000; font-weight: bold;">
                        Wyloguj
                    </button>
                </div>
            }
            else
            {
                <form id="loginForm" method="post" asp-controller="Auth" asp-action="Login" class="d-flex mb-2 w-100 px-3">
                    <input name="username" type="text" class="form-control form-control-sm me-2" placeholder="Login" required>
                    <input name="password" type="password" class="form-control form-control-sm me-2" placeholder="Hasło" required>
                    <button type="submit" class="btn btn-sm" style="background-color: #FFA31A; color: #000; font-weight: bold;">Zaloguj</button>
                </form>
                <div class="d-flex align-items-center mt-1">
                    <span class="small me-2 text-white">Nie masz konta?</span>
                    <button type="button" class="btn btn-sm btn-outline-light" style="border-color: #FFA31A; color: #FFA31A;" data-bs-toggle="modal" data-bs-target="#registerModal">
                        Zarejestruj się
                    </button>
                </div>
            }
        </div>
    </div>
    <div class="main_container">
        @RenderBody()
    </div>
    <div class="main_footer"></div>

    @* <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">pzpp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - pzpp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    *@

    <!-- Rejestracja pop-up -->
    <div class="modal fade" id="registerModal" tabindex="-1" aria-labelledby="registerModalLabel" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content" style="background-color: #292929; color: white; border: 1px solid #FFA31A;">
          <div class="modal-header border-bottom-0">
            <h5 class="modal-title" id="registerModalLabel">Rejestracja</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Zamknij"></button>
          </div>
          <div class="modal-body">
            <form id="registerForm" method="post" asp-controller="Auth" asp-action="Register">
              <div class="mb-3">
                <label class="form-label">Nazwa użytkownika</label>
                <input type="text" class="form-control" name="username" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Adres email</label>
                <input type="email" class="form-control" name="email" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Hasło</label>
                <input type="password" class="form-control" name="password" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Potwierdź hasło</label>
                <input type="password" class="form-control" name="confirmPassword" required>
              </div>
              <button type="submit" class="btn w-100 mt-2" style="background-color: #FFA31A; color: black; font-weight: bold;">Zarejestruj się</button>
               <div id="registerMessage" class="mt-2 text-center"></div> 
            </form>
          </div>
        </div>
      </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AJAX - zeby nie przeladowywal strony -->
    <script>
        $(document).ready(function () {
            function handleAjaxForm(formId, messageId, onSuccess) {
                $(formId).submit(function(e) {
                    e.preventDefault();

                    var form = $(this);
                    var url = form.attr('action');

                    $.ajax({
                        type: "POST",
                        url: url,
                        data: form.serialize(),
                        success: function(response) {
                            $(messageId)
                                .removeClass('text-danger')
                                .addClass('text-success')
                                .text(response);

                            if (onSuccess) onSuccess(form);
                        },
                        error: function(xhr) {
                            $(messageId)
                                .removeClass('text-success')
                                .addClass('text-danger')
                                .text(xhr.responseText);
                        }
                    });
                });
            }

            // Rejestracja
            handleAjaxForm('#registerForm', '#registerMessage', function(form) {
                setTimeout(function() {
                    $('#registerModal').modal('hide');
                }, 1500);
                form[0].reset();
            });

            // Logowanie
            handleAjaxForm('#loginForm', '#loginMessage', function(form) {
                setTimeout(function() {
                    location.reload();
                }, 1000);
            });

            // Wylogowanie
            $(document).on('click', '#logoutBtn', function() {
                $.ajax({
                    type: "POST",
                    url: '/Auth/Logout',
                    success: function(response) {
                        location.reload();
                    },
                    error: function(xhr) {
                        alert("Błąd przy wylogowaniu: " + xhr.responseText);
                    }
                });
            });
        });
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
